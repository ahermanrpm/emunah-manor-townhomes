<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Emunah Manor Apartments & Townhomes | 3-Bedroom Townhomes for Rent in Wilkes-Barre, PA</title>
<meta name="description" content="Spacious 3-bedroom townhomes for rent at Emunah Manor, 272 Coal St, Wilkes-Barre PA. Utilities included, yard & patio, free parking. Limited-time move-in special.">
<style>
  :root{
    --navy:#1c2e45;
    --deep:#13202f;
    --steel:#5d7c9e;
    --sky:#9fc0e3;
    --mist:#eef3f9;
    --paper:#ffffff;
    --ink:#1c2e45;
    --slate:#5e6c7d;
    --line: rgba(28,46,69,0.12);
    --line-light: rgba(255,255,255,0.18);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Inter', -apple-system, Helvetica, Arial, sans-serif;
    background:var(--paper);
    color:var(--ink);
    line-height:1.65;
    font-size:16px;
  }
  h1,h2,h3,.display{
    font-family:'Cormorant Garamond', Georgia, 'Times New Roman', serif;
    font-weight:600;
    letter-spacing:0.01em;
  }
  a{color:inherit;}
  img{display:block; max-width:100%;}

  .eyebrow{
    font-size:0.72rem; font-weight:600; letter-spacing:.28em; text-transform:uppercase;
    color:var(--steel); margin-bottom:18px;
  }

  /* ===== Header ===== */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    border-bottom:1px solid var(--line);
  }
  .nav{
    max-width:1240px; margin:0 auto; padding:18px 32px;
    display:flex; align-items:center; justify-content:space-between;
  }
  .brand{
    display:flex; align-items:center; gap:12px;
    text-decoration:none; color:var(--navy);
  }
  .brand img{width:34px; height:34px;}
  .brand-text{
    font-family:'Cormorant Garamond',serif; font-weight:600; font-size:1.3rem; letter-spacing:.04em;
  }
  .nav-links{display:flex; gap:40px; font-size:0.78rem; letter-spacing:.14em; text-transform:uppercase; font-weight:600;}
  .nav-links a{text-decoration:none; color:var(--slate); transition:color .2s;}
  .nav-links a:hover{color:var(--navy);}
  .nav-call{
    font-size:0.78rem; letter-spacing:.14em; text-transform:uppercase; font-weight:600;
    border:1px solid var(--navy); color:var(--navy); text-decoration:none;
    padding:11px 22px; transition:all .25s;
  }
  .nav-call:hover{background:var(--navy); color:#fff;}

  /* ===== Special banner ===== */
  .special-bar{
    background:var(--navy); color:var(--sky);
    text-align:center; font-size:0.74rem; font-weight:600;
    letter-spacing:.18em; text-transform:uppercase;
    padding:11px 16px;
  }
  .special-bar a{color:#fff; text-decoration:underline; text-decoration-color:var(--sky);}

  /* ===== Hero ===== */
  .hero{
    position:relative; height:88vh; min-height:560px;
    display:flex; align-items:flex-end;
    color:#fff;
  }
  .hero-bg{
    position:absolute; inset:0;
    background:
      linear-gradient(180deg, rgba(19,32,47,0.15) 0%, rgba(19,32,47,0.75) 100%),
      url('https://images1.apartments.com/i2/qCMutEXaw_MLiC5Z5It6ZMPuYZv8SJF4BpS_aIh5F7A/111/emunah-manor-apartments-wilkes-barre-pa-townhouse-living-roomdining-roomkitchen-.jpg') center/cover;
  }
  .hero-content{
    position:relative; max-width:1240px; margin:0 auto; padding:0 32px 90px;
    width:100%;
  }
  .hero-content .eyebrow{color:var(--sky);}
  .hero h1{
    font-size:clamp(2.8rem,6vw,4.6rem);
    line-height:1.08; font-weight:500;
    max-width:780px; margin-bottom:24px;
  }
  .hero p.lead{
    font-size:1.1rem; max-width:480px; color:rgba(255,255,255,0.82); margin-bottom:40px;
    font-weight:300;
  }
  .hero-ctas{display:flex; gap:18px; flex-wrap:wrap;}
  .btn{
    font-size:0.78rem; letter-spacing:.16em; text-transform:uppercase; font-weight:600;
    padding:17px 34px; text-decoration:none; display:inline-flex; align-items:center; gap:10px;
    transition:all .25s ease;
  }
  .btn-primary{background:#fff; color:var(--navy);}
  .btn-primary:hover{background:var(--sky);}
  .btn-outline{border:1px solid rgba(255,255,255,0.6); color:#fff;}
  .btn-outline:hover{background:rgba(255,255,255,0.12); border-color:#fff;}

  /* ===== Section shells ===== */
  section{padding:120px 32px;}
  .wrap{max-width:1240px; margin:0 auto;}
  .section-head{max-width:620px; margin-bottom:64px;}
  .section-head h2{font-size:clamp(2.2rem,4vw,3.2rem); font-weight:500; margin-bottom:18px;}
  .section-head p{color:var(--slate); font-size:1.02rem;}
  .center{text-align:center; margin-left:auto; margin-right:auto;}

  /* ===== Floor plan ===== */
  .plan-grid{
    display:grid; grid-template-columns: 1fr 1fr; gap:80px; align-items:center;
  }
  .plan-grid img{width:100%; aspect-ratio:4/5; object-fit:cover;}
  .plan-price{
    font-family:'Cormorant Garamond',serif; font-size:3.4rem; font-weight:600; color:var(--navy);
    margin:6px 0 28px;
  }
  .plan-price span{font-family:'Inter',sans-serif; font-size:0.95rem; color:var(--slate); font-weight:400; letter-spacing:.05em;}
  .plan-meta{
    display:flex; gap:0; border-top:1px solid var(--line); border-bottom:1px solid var(--line);
    margin:32px 0;
  }
  .plan-meta div{
    flex:1; padding:22px 0; border-right:1px solid var(--line);
  }
  .plan-meta div:last-child{border-right:none;}
  .plan-meta .v{font-family:'Cormorant Garamond',serif; font-weight:600; font-size:1.6rem; color:var(--navy);}
  .plan-meta .k{font-size:0.7rem; letter-spacing:.14em; text-transform:uppercase; color:var(--slate); margin-top:4px;}
  .plan-note{font-size:0.92rem; color:var(--slate); margin-bottom:32px;}

  .feature-list{margin-top:8px;}
  .feature-list li{
    list-style:none; display:flex; gap:14px; align-items:flex-start;
    padding:14px 0; border-bottom:1px solid var(--line); font-size:0.94rem; color:var(--ink);
  }
  .feature-list li:last-child{border-bottom:none;}
  .feature-list svg{flex:none; margin-top:2px; color:var(--steel);}

  /* ===== Gallery ===== */
  .gallery-section{background:var(--mist);}
  .gallery-grid{
    display:grid; grid-template-columns: repeat(4, 1fr); gap:18px;
  }
  .gallery-grid a:nth-child(1){grid-column:1/3; grid-row:1/3;}
  .gallery-grid a{display:block; overflow:hidden;}
  .gallery-grid a img{width:100%; height:100%; object-fit:cover; transition:transform .6s ease;}
  .gallery-grid a:nth-child(1) img{aspect-ratio:1/1;}
  .gallery-grid a:not(:nth-child(1)) img{aspect-ratio:1/1;}
  .gallery-grid a:hover img{transform:scale(1.05);}

  /* ===== Amenities ===== */
  .amen-grid{
    display:grid; grid-template-columns:repeat(4,1fr);
    border-top:1px solid var(--line); border-left:1px solid var(--line);
  }
  .amen-item{
    padding:40px 32px; border-right:1px solid var(--line); border-bottom:1px solid var(--line);
  }
  .amen-item svg{margin-bottom:20px; color:var(--steel);}
  .amen-item h4{font-family:'Cormorant Garamond',serif; font-weight:600; font-size:1.25rem; margin-bottom:8px;}
  .amen-item p{font-size:0.88rem; color:var(--slate);}

  /* ===== Neighborhood ===== */
  .neigh-section{background:var(--navy); color:#fff;}
  .neigh-section .eyebrow{color:var(--sky);}
  .neigh-section .section-head p{color:rgba(255,255,255,0.65);}
  .neigh{display:grid; grid-template-columns: 1fr 1fr; gap:80px; align-items:center;}
  .neigh-list li{
    list-style:none; display:flex; justify-content:space-between;
    padding:18px 0; border-bottom:1px solid var(--line-light); font-size:0.95rem;
  }
  .neigh-list li span:first-child{font-weight:500;}
  .neigh-list li span:last-child{color:var(--sky); font-size:0.85rem; letter-spacing:.05em;}
  .neigh-map-frame{height:420px; border:1px solid var(--line-light); filter: grayscale(15%);}
  .neigh-map-frame iframe{width:100%; height:100%; border:0;}

  /* ===== CTA / Contact ===== */
  .cta-section{text-align:center; background:var(--mist);}
  .cta-section .eyebrow{justify-content:center; text-align:center;}
  .cta-section h2{font-size:clamp(2.2rem,4.4vw,3.4rem); font-weight:500; margin-bottom:20px;}
  .cta-section p{color:var(--slate); max-width:560px; margin:0 auto 44px; font-size:1.02rem;}
  .cta-row{display:flex; gap:18px; justify-content:center; flex-wrap:wrap; margin-bottom:64px;}
  .cta-row .btn-primary{background:var(--navy); color:#fff;}
  .cta-row .btn-primary:hover{background:var(--steel);}
  .cta-row .btn-outline{border:1px solid var(--navy); color:var(--navy);}
  .cta-row .btn-outline:hover{background:var(--navy); color:#fff;}
  .cta-details{
    display:flex; justify-content:center; gap:80px; flex-wrap:wrap;
    border-top:1px solid var(--line); padding-top:48px;
  }
  .cta-details .k{font-size:0.7rem; text-transform:uppercase; letter-spacing:.18em; color:var(--steel); margin-bottom:8px;}
  .cta-details .v{font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:600;}

  /* ===== Footer ===== */
  footer{
    background:var(--deep); color:rgba(255,255,255,0.55);
    text-align:center; padding:48px 32px; font-size:0.82rem;
  }
  footer .foot-brand{
    display:flex; align-items:center; justify-content:center; gap:10px;
    margin-bottom:18px; color:#fff;
  }
  footer .foot-brand img{width:24px; height:24px;}
  footer .foot-brand span{font-family:'Cormorant Garamond',serif; font-size:1.1rem; letter-spacing:.05em;}
  footer .owner{
    margin-top:18px; padding-top:18px; border-top:1px solid var(--line-light);
    font-size:0.76rem; letter-spacing:.06em; color:rgba(255,255,255,0.4);
  }
  footer a{color:rgba(255,255,255,0.65); text-decoration:underline;}

  /* ===== Responsive ===== */
  @media (max-width:880px){
    .nav-links{display:none;}
    .plan-grid, .neigh{grid-template-columns:1fr; gap:48px;}
    .gallery-grid{grid-template-columns:repeat(2,1fr);}
    .gallery-grid a:nth-child(1){grid-column:1/3; grid-row:1/2;}
    .amen-grid{grid-template-columns:repeat(2,1fr);}
    section{padding:80px 20px;}
    .hero{height:auto; min-height:640px; padding-top:140px;}
    .cta-details{gap:36px;}
  }
  @media (max-width:520px){
    .amen-grid{grid-template-columns:1fr;}
    .plan-meta{flex-direction:column;}
    .plan-meta div{border-right:none; border-bottom:1px solid var(--line);}
    .plan-meta div:last-child{border-bottom:none;}
  }
</style>
</head>
<body>

<!-- ===================== HEADER ===================== -->
<header>
  <div class="special-bar">
    LIMITED-TIME 3-BEDROOM TOWNHOME SPECIAL — $99 SECURITY DEPOSIT + 50% OFF 1ST MONTH + FREE APPLICATION &nbsp; <a href="#contact">Details &rarr;</a>
  </div>
  <div class="nav">
    <a href="#" class="brand">
      <img src="logo.png" alt="Emunah Manor logo">
      <span class="brand-text">Emunah Manor</span>
    </a>
    <nav class="nav-links">
      <a href="#townhome">Residence</a>
      <a href="#gallery">Gallery</a>
      <a href="#amenities">Amenities</a>
      <a href="#neighborhood">Location</a>
    </nav>
    <a href="tel:5708223276" class="nav-call">(570) 822-3276</a>
  </div>
</header>

<!-- ===================== HERO ===================== -->
<section class="hero" style="padding:0;">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="eyebrow">272 Coal St &middot; Wilkes-Barre, Pennsylvania</div>
    <h1>A three-bedroom<br>townhome of your own.</h1>
    <p class="lead">Private yard and patio, utilities included, and a quiet residential setting minutes from King's College and Wilkes University.</p>
    <div class="hero-ctas">
      <a href="#contact" class="btn btn-primary">Schedule a Tour</a>
      <a href="#townhome" class="btn btn-outline">View the Residence</a>
    </div>
  </div>
</section>

<!-- ===================== TOWNHOME / FLOOR PLAN ===================== -->
<section id="townhome">
  <div class="wrap">
    <div class="plan-grid">
      <img src="https://images1.apartments.com/i2/YzLMTShddpP0_g2B62LXsImjCJm_uvmC0Z6f4rKAN9E/116/emunah-manor-apartments-wilkes-barre-pa-townhouse-kitchen.jpg" alt="Townhouse kitchen at Emunah Manor">
      <div>
        <div class="eyebrow">The Residence</div>
        <h2>The Three-Bedroom Townhome</h2>
        <div class="plan-price">$1,699 <span>per month</span></div>
        <div class="plan-meta">
          <div><div class="v">3 / 1</div><div class="k">Bed / Bath</div></div>
          <div><div class="v">950</div><div class="k">Square Feet</div></div>
          <div><div class="v">12 mo</div><div class="k">Lease Term</div></div>
        </div>
        <p class="plan-note">Multiple units available — some ready now, others available July 1. Contact our leasing office for current availability.</p>
        <ul class="feature-list">
          <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg> Private yard and patio</li>
          <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg> Gas, water, electric, trash &amp; sewer included</li>
          <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg> Stainless appliances &amp; vinyl flooring</li>
          <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Washer/dryer hookup — stackable unit available (+$100/mo)</li>
        </ul>
        <div style="margin-top:40px;">
          <a href="#contact" class="btn btn-primary" style="background:var(--navy); color:#fff;">Check Availability</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== GALLERY ===================== -->
<section class="gallery-section" id="gallery">
  <div class="wrap">
    <div class="section-head center">
      <div class="eyebrow">A Closer Look</div>
      <h2>Inside the townhome</h2>
      <p>Bright kitchens, generous bedrooms, and a layout designed for everyday living.</p>
    </div>
    <div class="gallery-grid">
      <a href="#"><img src="https://images1.apartments.com/i2/qCMutEXaw_MLiC5Z5It6ZMPuYZv8SJF4BpS_aIh5F7A/111/emunah-manor-apartments-wilkes-barre-pa-townhouse-living-roomdining-roomkitchen-.jpg" alt="Townhome living room, dining room and kitchen"></a>
      <a href="#"><img src="https://images1.apartments.com/i2/bajy_vsEt1fb9twXIDXIGMRxbKm9k2fEws9yen7Fm60/111/emunah-manor-apartments-wilkes-barre-pa-townhouse-master-bedroom.jpg" alt="Townhouse master bedroom"></a>
      <a href="#"><img src="https://images1.apartments.com/i2/9EbZPnRWcH9JSmJKsb361037rjEYTTJg5lQoqIDnXNQ/111/emunah-manor-apartments-wilkes-barre-pa-townhouse-kitchen.jpg" alt="Townhouse kitchen, second view"></a>
      <a href="#"><img src="https://images1.apartments.com/i2/-tOJtB_XNW0Nu0KKUF6LHIidKt8XL2NOU3EBD5Yqb34/111/emunah-manor-apartments-wilkes-barre-pa-townhouse-kitchen.jpg" alt="Townhouse kitchen, third view"></a>
    </div>
  </div>
</section>

<!-- ===================== AMENITIES ===================== -->
<section id="amenities">
  <div class="wrap">
    <div class="section-head">
      <div class="eyebrow">Community Amenities</div>
      <h2>Everything in its place</h2>
      <p>Beyond your front door, Emunah Manor offers the everyday conveniences that make renting effortless.</p>
    </div>
    <div class="amen-grid">
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        <h4>Utilities Included</h4>
        <p>Gas, water, electric, trash and sewer are all included in your rent.</p>
      </div>
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        <h4>24/7 Security</h4>
        <p>Round-the-clock camera monitoring across the community.</p>
      </div>
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        <h4>Maintenance, Day or Night</h4>
        <p>On-site maintenance available 24 hours a day for peace of mind.</p>
      </div>
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22h20M4 22V8l8-6 8 6v14M9 22V14h6v8"/></svg>
        <h4>Resident Playground</h4>
        <p>A newly installed playground, ideal for families with children.</p>
      </div>
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><path d="M5 17H3V9l2-5h9l4 5h2v8h-2"/><path d="M14 9H9"/></svg>
        <h4>Free Parking</h4>
        <p>On-site parking included — no extra fees or permits.</p>
      </div>
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        <h4>On-Site Laundry</h4>
        <p>Shared laundry facility on-site, or add a stackable washer/dryer.</p>
      </div>
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <h4>Yard &amp; Patio</h4>
        <p>Your own private outdoor space — rare for the price in this area.</p>
      </div>
      <div class="amen-item">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 2 9 2 12 0v-5"/></svg>
        <h4>Walk to Local Colleges</h4>
        <p>Minutes from Wilkes University and King's College — student-friendly leasing.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===================== NEIGHBORHOOD ===================== -->
<section class="neigh-section" id="neighborhood">
  <div class="wrap">
    <div class="neigh">
      <div>
        <div class="eyebrow">The Setting</div>
        <h2 style="font-size:clamp(2.2rem,4vw,3.2rem); font-weight:500; margin-bottom:18px;">Settled into Wilkes-Barre</h2>
        <p style="color:rgba(255,255,255,0.65); margin-bottom:8px;">Coal Street sits in a walkable, family-friendly pocket of Wilkes-Barre, close to shopping, schools, and the city's parks and riverfront trails.</p>
        <ul class="neigh-list">
          <li><span>King's College</span><span>4 min drive</span></li>
          <li><span>Wilkes University</span><span>4 min drive</span></li>
          <li><span>City Heights Shopping Center</span><span>8 min walk</span></li>
          <li><span>Wilkes-Barre General Hospital</span><span>4 min drive</span></li>
          <li><span>Wilkes-Barre/Scranton Int'l Airport</span><span>20 min drive</span></li>
        </ul>
      </div>
      <div class="neigh-map-frame">
        <iframe src="https://www.google.com/maps?q=272+Coal+St,+Wilkes-Barre,+PA+18702&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Map of 272 Coal St, Wilkes-Barre, PA"></iframe>
      </div>
    </div>
  </div>
</section>

<!-- ===================== CONTACT / CTA ===================== -->
<section class="cta-section" id="contact">
  <div class="wrap">
    <div class="eyebrow">Move-In Special</div>
    <h2 class="center">$99 deposit. Half off your first month.<br>Free application.</h2>
    <p class="center">Move into a 3-bedroom townhome within 30 days and save big. Apply the same day as your tour or showing to qualify — subject to standard screening requirements. This offer won't last, so call today.</p>
